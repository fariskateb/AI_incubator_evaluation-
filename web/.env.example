# ── Database (Neon Postgres) ──────────────────────────────────────────
# Create a project at https://neon.tech and copy the pooled connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── better-auth ───────────────────────────────────────────────────────
# Generate a secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# ── Anthropic (server-side only — never exposed to the browser) ───────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Resend (optional — report emails). Leave blank to disable sending. ──
# Get a key at https://resend.com and verify a sending domain.
RESEND_API_KEY=""
RESEND_FROM="حاضنة الذكاء الاصطناعي <reports@incubator.kau.edu.sa>"

# ── First admin (seeded by `pnpm db:seed`) ────────────────────────────
SEED_ADMIN_EMAIL="admin@kau.edu.sa"
SEED_ADMIN_PASSWORD="change-me-please"
SEED_ADMIN_NAME="المشرف العام"
